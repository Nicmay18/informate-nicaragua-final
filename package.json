{
  "name": "informate-nicaragua-final",
  "version": "2.0.0",
  "description": "Nicaragua Infórmate — Periodismo de Precisión (Next.js 15 + Firebase)",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run lint && npm run type-check && npm run test && npm run test:e2e",
    "pre-deploy": "bash scripts/pre-deploy-check.sh",
    "audit": "node scripts/audit-costs.mjs",
    "scripts:organize": "node scripts/cli.js organize"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "autoprefixer": "^10.4.21",
    "date-fns": "^4.2.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^12.7.0",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.14.0",
    "next": "15.3.9",
    "postcss": "^8.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "dotenv": "^17.4.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.9",
    "jsdom": "^24.1.1",
    "typescript": "^5",
    "vitest": "^2.0.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nicmay18/informate-nicaragua-final.git"
