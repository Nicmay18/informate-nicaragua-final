# ─────────────────────────────────────────────────────
# DISTRIBUCIÓN AUTOMÁTICA (5 canales)
# ─────────────────────────────────────────────────────

# Telegram — @BotFather → /newbot → copiar token
# Chat ID: crea canal → agrega bot admin → visita:
# https://api.telegram.org/bot<TOKEN>/getUpdates
TG_TOKEN=
TG_CHAT_ID=

# OneSignal Push — Dashboard → Settings → Keys & IDs
ONESIGNAL_APP_ID=608354d3-fd2a-4c97-b055-5c14b57bbe9b
ONESIGNAL_REST_API_KEY=

# Facebook — Meta for Developers → Token de página permanente
FB_PAGE_TOKEN=
FB_PAGE_ID=

# Twitter/X API v2 — requiere OAuth 2.0 User Context (Bearer NO sirve para postear)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_REFRESH_TOKEN=
TWITTER_BEARER_TOKEN=

# ─────────────────────────────────────────────────────
# Firebase Admin SDK — Build-time / Server-side only
# Obtén estos valores en Firebase Console →
# Configuración del proyecto → Cuentas de servicio →
# Generar nueva clave privada (JSON)
# ─────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=informate-instant-nicaragua
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@informate-instant-nicaragua.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────────────────
# AGENTE DE INDEXACIÓN (Search Engines)
# ─────────────────────────────────────────────────────

# IndexNow — clave aleatoria de 64 chars (gratis, Bing/Yahoo/DuckDuckGo)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INDEXNOW_KEY=1da93d2cbffb6f92d3a56cffab2a08e528e2e0b5f24ec61dde4275c018edf16e

# Google Indexing API — opcional, requiere Google Cloud setup
# 1. Crear proyecto en Google Cloud Console
# 2. Habilitar "Indexing API"
# 3. Crear cuenta de servicio → descargar JSON
# 4. En Search Console → agregar cuenta de servicio como "Propietario"
# 5. Codificar JSON en base64: node -e "const fs=require('fs');console.log(fs.readFileSync('service-account.json').toString('base64'))"
# GOOGLE_INDEXING_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50I...base64...

# ─────────────────────────────────────────────────────
# Copia este archivo como .env.local y rellena los
# valores reales. NUNCA subas .env.local a Git.
# ─────────────────────────────────────────────────────
