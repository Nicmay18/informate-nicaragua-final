rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== NOTICIAS ==========
    // ⚠️ SEGURIDAD CRÍTICA: TODAS las escrituras están bloqueadas para clientes.
    // El backend (Next.js Route Handlers / Server Actions) usa Firebase Admin SDK,
    // el cual BLOQUEA las security rules por completo y opera con privilegios de
    // service account. Esto garantiza que NUNCA un usuario público pueda modificar
    // noticias desde el navegador, incluso si obtiene el API key del cliente.
    match /noticias/{noticiaId} {
      // Lectura pública (todo el mundo puede leer noticias)
      allow get, list: if true;

      // CREATE: permitido desde el panel admin (Client SDK) con validación estricta.
      // Se exige que vengan los campos mínimos para evitar documentos vacíos.
      allow create: if request.resource.data.keys().hasAll(['titulo','contenido','categoria','fecha'])
          && request.resource.data.titulo is string
          && request.resource.data.titulo.size() > 0
          && request.resource.data.titulo.size() <= 200
          && request.resource.data.contenido is string
          && request.resource.data.contenido.size() <= 50000
          && request.resource.data.categoria in ['Sucesos','Nacionales','Deportes','Internacionales','Espectáculos','Tecnología'];

      // UPDATE: permitido desde el panel admin. Valida solo los campos que se envíen.
      // Permite actualizaciones parciales como {publicado: true} o {destacada: true}.
      allow update: if
          (!('titulo' in request.resource.data) || (request.resource.data.titulo is string && request.resource.data.titulo.size() > 0 && request.resource.data.titulo.size() <= 200))
          && (!('contenido' in request.resource.data) || (request.resource.data.contenido is string && request.resource.data.contenido.size() <= 50000))
          && (!('categoria' in request.resource.data) || request.resource.data.categoria in ['Sucesos','Nacionales','Deportes','Internacionales','Espectáculos','Tecnología']);

      // DELETE: bloqueado para clientes. Solo backend vía adminDb.
      allow delete: if false;
    }

    // ========== NEWSLETTER SUBSCRIBERS ==========
    match /newsletter_subscribers/{email} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.resource.data.email == email
          && request.resource.data.email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$')
          && request.resource.data.status == 'active'
          && request.resource.data.subscribedAt is timestamp;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ========== COMENTARIOS ==========
    match /comentarios/{comentarioId} {
      allow read: if true;
      allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.contenido is string
          && request.resource.data.contenido.size() > 0
          && request.resource.data.contenido.size() <= 2000
          && request.resource.data.createdAt is timestamp;
      allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
    }

    // ========== ADMIN ONLY ==========
    match /newsletter_campaigns/{campaignId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /newsletter_sponsors/{sponsorId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /sponsored_campaigns/{campaignId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /analytics/{docId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ========== CONFIGURACIÓN ==========
    // ⚠️ NUNCA dejes write en true: cualquiera podría destruir tu app
    match /config/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}