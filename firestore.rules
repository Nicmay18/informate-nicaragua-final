rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== NOTICIAS ==========
    match /noticias/{noticiaId} {
      // Lectura pública
      allow get, list: if true;

      // CREATE: todos los campos obligatorios deben venir
      allow create: if true
          && request.resource.data.keys().hasAll([
               'titulo','contenido','categoria','fecha'
             ])
          && request.resource.data.keys().hasOnly([
               'titulo','resumen','contenido','categoria','autor',
               'fecha','fechaActualizacion','imagen','slug','destacada',
               'premium','vistas','tags','pieFoto','tiempoLectura',
               'departamento','dateline','esFallecido','palabras'
             ])
          && request.resource.data.titulo is string
          && request.resource.data.titulo.size() > 0
          && request.resource.data.titulo.size() <= 200
          && request.resource.data.contenido is string
          && request.resource.data.contenido.size() <= 50000
          && request.resource.data.categoria in [
               'Sucesos','Nacionales','Deportes','Internacionales','Espectáculos'
             ];

      // UPDATE: validar SOLO los campos que se envían (update parcial)
      allow update: if true
          && request.resource.data.keys().hasOnly([
               'titulo','resumen','contenido','categoria','autor',
               'fecha','fechaActualizacion','imagen','slug','destacada',
               'premium','vistas','tags','pieFoto','tiempoLectura',
               'departamento','dateline','esFallecido','palabras'
             ])
          && (!request.resource.data.keys().hasAny(['titulo']) || (
               request.resource.data.titulo is string
               && request.resource.data.titulo.size() > 0
               && request.resource.data.titulo.size() <= 200
             ))
          && (!request.resource.data.keys().hasAny(['contenido']) || (
               request.resource.data.contenido is string
               && request.resource.data.contenido.size() <= 50000
             ))
          && (!request.resource.data.keys().hasAny(['categoria']) || (
               request.resource.data.categoria in [
                 'Sucesos','Nacionales','Deportes','Internacionales','Espectáculos'
               ]
             ));

      // DELETE: solo admins (¡cuidado con dejarlo en true!)
      allow delete: if true;
    }

    // ========== NEWSLETTER SUBSCRIBERS ==========
    match /newsletter_subscribers/{email} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow create: if request.resource.data.email == email
          && request.resource.data.email.matches('^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$')
          && request.resource.data.status == 'active'
          && request.resource.data.subscribedAt is timestamp;
      allow update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // ========== COMENTARIOS ==========
    match /comentarios/{comentarioId} {
      allow read: if true;
      allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.contenido is string
          && request.resource.data.contenido.size() > 0
          && request.resource.data.contenido.size() <= 2000
          && request.resource.data.createdAt is timestamp;
      allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
    }

    // ========== ADMIN ONLY ==========
    match /newsletter_campaigns/{campaignId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /newsletter_sponsors/{sponsorId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /sponsored_campaigns/{campaignId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    match /analytics/{docId} {
      allow read: if request.auth != null && request.auth.token.admin == true;
      allow write: if false;
    }

    // ========== CONFIGURACIÓN ==========
    // ⚠️ NUNCA dejes write en true: cualquiera podría destruir tu app
    match /config/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}